[user]
	name = {{GIT_USER_NAME}}
	email = {{GIT_USER_EMAIL}}

[init]
	defaultBranch = main

[core]
	editor = {{GIT_EDITOR}}
	excludesfile = ~/.config/git/ignore

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[rerere]
	enabled = true

[diff]
	algorithm = histogram

[merge]
	conflictstyle = zdiff3
